#include <iostream>
using namespace std;


float areaCirculo(float radio){
    return 3.1416 * radio * radio;
}


int factorial(int n){
    int fact = 1;
    for(int i = 1; i <= n; i++){
        fact *= i;
    }
    return fact;
}


void parImpar(int n){
    if(n % 2 == 0){
        cout << "El numero es par\n";
    } else {
        cout << "El numero es impar\n";
    }
}

int main(){
    int opcion;
    
    do{
        cout << "\nMENU\n";
        cout << "1. Area de un circulo\n";
        cout << "2. Factorial\n";
        cout << "3. Par o impar\n";
        cout << "4. Salir\n";
        cout << "Opcion: ";
        cin >> opcion;
        
        if(opcion == 1){
            float r;
            cout << "Ingrese el radio: ";
            cin >> r;
            cout << "Area = " << areaCirculo(r) << endl;
        }
        else if(opcion == 2){
            int n;
            cout << "Ingrese el numero: ";
            cin >> n;
            cout << "Factorial = " << factorial(n) << endl;
        }
        else if(opcion == 3){
            int n;
            cout << "Ingrese el numero: ";
            cin >> n;
            parImpar(n);
        }
        
    }while(opcion != 4);

    return 0;
}
