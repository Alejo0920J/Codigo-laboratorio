#include <iostream>
#include <fstream>
#include <vector>
using namespace std;

class Tarea {
public:
    string nombre;
    int prioridad;
    string fecha;
    string estado;

    Tarea(string n, int p, string f) {
        nombre = n;
        prioridad = p;
        fecha = f;
        estado = "pendiente";
    }

    void marcarCompletada() {
        estado = "completada";
    }

    void mostrar() {
        cout << nombre << " | Prioridad: " << prioridad 
             << " | Fecha: " << fecha 
             << " | Estado: " << estado << endl;
    }
};

int main() {
    vector<Tarea> tareas;
    int op;

    do {
        cout << "\n1. Agregar tarea\n2. Mostrar tareas\n3. Guardar en archivo\n4. Recomendacion\n5. Salir\nOpcion: ";
        cin >> op;

        if (op == 1) {
            string nombre, fecha;
            int prioridad;

            cin.ignore();
            cout << "Nombre: ";
            getline(cin, nombre);
            cout << "Prioridad (1-3): ";
            cin >> prioridad;
            cout << "Fecha limite (ej: 2026): ";
            cin >> fecha;

            tareas.push_back(Tarea(nombre, prioridad, fecha));
        }

        else if (op == 2) {
            for (int i = 0; i < tareas.size(); i++) {
                tareas[i].mostrar();
            }
        }

        else if (op == 3) {
            ofstream f("tareas.txt");
            for (int i = 0; i < tareas.size(); i++) {
                f << tareas[i].nombre << "," 
                  << tareas[i].prioridad << "," 
                  << tareas[i].fecha << "," 
                  << tareas[i].estado << endl;
            }
            f.close();
            cout << "Guardado en archivo\n";
        }

        else if (op == 4) {
            int pendientes = 0;

            for (int i = 0; i < tareas.size(); i++) {
                if (tareas[i].estado == "pendiente") {
                    pendientes++;

                    if (tareas[i].prioridad == 3) {
                        cout << "Recomendacion: Haz primero -> " 
                             << tareas[i].nombre << endl;
                    }
                }
            }

            if (pendientes > 3) {
                cout << "Tienes muchas tareas pendientes, organiza tu tiempo\n";
            }
        }

    } while (op != 5);

    return 0;
}
